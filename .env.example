# ============================================================
# GIS Stack — Environment Configuration
# Copy this file to .env and fill in all CHANGE_ME values.
# NEVER commit .env to git — it is already in .gitignore.
#
# DATABASE_URL is NOT set here; docker-compose constructs it
# automatically from the POSTGRES_* variables below.
#
# The *_PORT variables control which HOST port each service
# is accessible on directly (for debugging). In production all
# traffic should go through Nginx on NGINX_PORT (80 / 443).
# ============================================================

# --- PostGIS ---
POSTGRES_DB=gisdb
POSTGRES_USER=gisuser
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGIS_PORT=5432         # host-side port for direct psql access

# --- GeoServer ---
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=CHANGE_ME_strong_password
GEOSERVER_PORT=8080
GEOSERVER_INITIAL_MEMORY=512M
GEOSERVER_MAXIMUM_MEMORY=1536M

# --- Martin ---
MARTIN_PORT=3000

# --- pgAdmin ---
PGADMIN_EMAIL=admin@gis.local
PGADMIN_PASSWORD=CHANGE_ME_strong_password
PGADMIN_PORT=5050

# --- Nginx (main entry point) ---
NGINX_PORT=80
